  <num>KL-CY-2026-011</num>
  <heading>Kiowa Tribe Annual Budget Appropriation for Fiscal Year 2026-2027</heading>
  <meta>
    <effective>2026-03-30</effective>
    <history>
      <adopted>2026-03-26</adopted>
    </history>
    <citations>
